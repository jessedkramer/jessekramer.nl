{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "jessekramer-nl.vercel.app"
        }
      ],
      "destination": "https://jessekramer.nl/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.jessekramer.nl"
        }
      ],
      "destination": "https://jessekramer.nl/$1",
      "permanent": true
    }
  ]
}
